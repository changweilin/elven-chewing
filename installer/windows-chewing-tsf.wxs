<?xml version="1.0" encoding="UTF-8"?>

<?include version.wxi?>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
    xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
    xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
    <Package Name="精靈語輸入法 (TSF)"
        Codepage="65001"
        Language="1028"
        Manufacturer="精靈語輸入法開發團隊"
        Version="$(var.Version)"
        UpgradeStrategy="majorUpgrade"
        UpgradeCode="b77fb1ad-b915-469f-afee-154d0e120774">
        <MajorUpgrade AllowDowngrades="yes" />
        <MediaTemplate CompressionLevel="high" EmbedCab="yes" />
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="精靈語輸入法 (TSF)" />
        </StandardDirectory>
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER64" Name="ElvenIME">
                <Directory Id="Dictionary" Name="Dictionary">
                    <File Source="Dictionary\swkb.dat" Bitness="always64" />
                    <File Source="Dictionary\symbols.dat" Bitness="always64" />
                    <File Source="Dictionary\tsi.dat" Bitness="always64" />
                    <File Source="Dictionary\word.dat" Bitness="always64" />
                    <Directory Name="dictionary.d">
                        <File Source="Dictionary\alt.dat" Bitness="always64" />
                    </Directory>
                </Directory>
                <Component Bitness="always64">
                    <File Source="x64\chewing_tip.dll">
                        <Class Advertise="no" Context="InprocServer32" Description="精靈語輸入法 (TSF)"
                            Id="DE733D27-7EEB-4C3B-9EEC-715F05B5BA85" IconIndex="0"
                            ThreadingModel="apartment" />
                    </File>
                    <!-- Remove NSIS Uninstaller -->
                    <RemoveFile Name="Uninstall.exe" On="install" />
                </Component>
                <Component Bitness="always64">
                    <File Source="ChewingPreferences.exe" KeyPath="yes">
                        <Shortcut Advertise="yes" Icon="icon.exe" Name="設定精靈語輸入法" Directory="ApplicationProgramsFolder" />
                    </File>
                    <RemoveFolder Directory="ApplicationProgramsFolder" On="uninstall" />
                </Component>
                <Component Bitness="always64">
                    <File Source="chewing-editor.exe" KeyPath="yes">
                        <Shortcut Advertise="yes" Icon="icon.exe" Name="編輯精靈語使用者詞庫" Directory="ApplicationProgramsFolder" />
                    </File>
                </Component>
                <File Source="WebView2Loader.dll" Bitness="always64" />
                <File Source="chewing-cli.exe" Bitness="always64" />
                <File Source="chewing_tip_host.exe" Bitness="always64" />
                <File Source="chewing.ico" />
                <File Source="version.json" />
                <Component Bitness="always64">
                    <!-- Main protocol key -->
                    <RegistryKey Root="HKCR" Key="elven-ime-preferences">
                        <RegistryValue Type="string" Value="URL:ElvenIME Preferences" />
                        <RegistryValue Name="URL Protocol" Type="string" Value="" />
                    </RegistryKey>
                    <!-- Default icon -->
                    <RegistryKey Root="HKCR" Key="elven-ime-preferences\DefaultIcon">
                        <RegistryValue Type="string" Value="[INSTALLFOLDER64]ChewingPreferences.exe,0" />
                    </RegistryKey>
                    <!-- Shell command -->
                    <RegistryKey Root="HKCR" Key="elven-ime-preferences\shell\open\command">
                        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER64]ChewingPreferences.exe&quot; &quot;%1&quot;" />
                    </RegistryKey>
                    <!-- Main protocol key -->
                    <RegistryKey Root="HKCR" Key="elven-ime-editor">
                        <RegistryValue Type="string" Value="URL:ElvenIME Editor" />
                        <RegistryValue Name="URL Protocol" Type="string" Value="" />
                    </RegistryKey>
                    <!-- Default icon -->
                    <RegistryKey Root="HKCR" Key="elven-ime-editor\DefaultIcon">
                        <RegistryValue Type="string" Value="[INSTALLFOLDER64]chewing-editor.exe,0" />
                    </RegistryKey>
                    <!-- Shell command -->
                    <RegistryKey Root="HKCR" Key="elven-ime-editor\shell\open\command">
                        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER64]chewing-editor.exe&quot; &quot;%1&quot;" />
                    </RegistryKey>
                    <!-- Main protocol key -->
                    <RegistryKey Root="HKCR" Key="elven-ime-host">
                        <RegistryValue Type="string" Value="URL:ElvenIME TIP Host" />
                        <RegistryValue Name="URL Protocol" Type="string" Value="" />
                    </RegistryKey>
                    <!-- Default icon -->
                    <RegistryKey Root="HKCR" Key="elven-ime-host\DefaultIcon">
                        <RegistryValue Type="string" Value="[INSTALLFOLDER64]chewing_tip_host.exe,0" />
                    </RegistryKey>
                    <!-- Shell command -->
                    <RegistryKey Root="HKCR" Key="elven-ime-host\shell\open\command">
                        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER64]chewing_tip_host.exe&quot; &quot;%1&quot;" />
                    </RegistryKey>

                    <!-- Start elven IME host after login -->
                    <RegistryKey Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run">
                         <RegistryValue Type="string"
                                        Name="ElvenIMEHost"
                                        Value="[INSTALLFOLDER64]chewing_tip_host.exe" />
                    </RegistryKey>
                </Component>
            </Directory>
        </StandardDirectory>
        <StandardDirectory Id="ProgramFilesFolder">
            <Directory Id="INSTALLFOLDER32" Name="ElvenIME">
                <Component Bitness="always32">
                    <File Source="x86\chewing_tip.dll">
                        <Class Advertise="no" Context="InprocServer32" Description="精靈語輸入法 (TSF)"
                            Id="DE733D27-7EEB-4C3B-9EEC-715F05B5BA85" IconIndex="0"
                            ThreadingModel="apartment" />
                    </File>
                    <!-- Remove NSIS Uninstaller -->
                    <RemoveFile Name="Uninstall.exe" On="install" />
                </Component>
            </Directory>
        </StandardDirectory>
        <Icon Id="icon.exe" SourceFile="chewing.ico" />
        <Binary Id="tsfreg" SourceFile="tsfreg.exe" />
        <CustomAction Id="RegisterTSF" BinaryRef="tsfreg"
            ExeCommand="-r &quot;[INSTALLFOLDER64]chewing.ico&quot;"
            Impersonate="no" Execute="deferred" Return="check" />
        <CustomAction Id="UnregisterTSF" BinaryRef="tsfreg" ExeCommand="-u" Impersonate="no" Execute="deferred" Return="check" />
        <CustomAction Id="EnableTIP" BinaryRef="tsfreg" ExeCommand="-i" Impersonate="yes" Execute="deferred" Return="check" />
        <CustomAction Id="DisableTIP" BinaryRef="tsfreg" ExeCommand="-d" Impersonate="yes" Execute="deferred" Return="check" />
        <CustomAction Id="StopChewingTipHost" BinaryRef="tsfreg" ExeCommand="-s" Impersonate="yes" Execute="immediate" Return="check" />
        <InstallExecuteSequence>
            <Custom Action="StopChewingTipHost" Before="InstallValidate" />
            <Custom Action="RegisterTSF" After="WriteRegistryValues"
                Condition='Installed="" AND PREVIOUSVERSIONSINSTALLED=""' />
            <Custom Action="EnableTIP" After="RegisterTSF"
                Condition='Installed="" AND PREVIOUSVERSIONSINSTALLED=""' />
            <Custom Action="UnregisterTSF" Before="RemoveRegistryValues"
                Condition='PREVIOUSVERSIONSINSTALLED="" AND REMOVE="ALL"' />
            <Custom Action="DisableTIP" Before="UnregisterTSF"
                Condition='PREVIOUSVERSIONSINSTALLED="" AND REMOVE="ALL"' />
        </InstallExecuteSequence>
        <ui:WixUI Id="WixUI_Minimal" />
        <WixVariable Id="WixUILicenseRtf" Value="gpl-notice.rtf" />

        <!--
            精靈語輸入法 與 新酷音輸入法 可同時安裝、各自獨立。
            因此不再偵測或移除既有的 ChewingTextService NSIS 安裝。
        -->
    </Package>
</Wix>
